# Neon PostgreSQL (tùy chọn — chỉ cần khi muốn persist lịch sử/thống kê & seed từ khóa)
# Lấy chuỗi kết nối tại https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Cổng & host cho custom server (mặc định 3000 / 0.0.0.0)
PORT=3000
HOST=0.0.0.0
